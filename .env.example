# 🦈 SHARK CLI - Environment Configuration
# ============================================
# ALL KEYS ARE MANDATORY - NO OPTIONAL FIELDS
# Copy this file to .env and fill in ALL values
# ============================================

# MICRO ENGINEER MODE (Precision Coding)
# ============================================
# Gemma 3 4B (Execution Brain) - FREE tier, 14k RPD
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# DeepSeek R1 (Planning Brain)
# Get your key: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# MACRO ENGINEER MODE (Systems Engineering)
# ============================================
# GLM 4.5-flash (Primary Brain)
# Use GLM_API_KEY OR GLM_CODING_PLAN_KEY (either works)
# Get your key: https://open.bigmodel.cn
GLM_API_KEY=your-glm-api-key-here
# OR use coding plan key:
# GLM_CODING_PLAN_KEY=your-coding-plan-key-here

# ============================================
# SYSTEM SETTINGS (Do not change defaults)
# ============================================
SHARK_DEBUG=false
SHARK_REGION=sea
SHARK_AUTO_APPROVE=false
